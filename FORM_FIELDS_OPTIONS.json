{
  "formFields": {
    "userInputFields": {
      "zipCode": {
        "type": "text",
        "required": true,
        "validation": "Must be exactly 5 digits",
        "format": "string",
        "example": "60601"
      },
      "homeOwnership": {
        "type": "radio",
        "required": true,
        "options": [
          "yes",
          "no"
        ],
        "example": "yes"
      },
      "electricBill": {
        "type": "radio",
        "required": true,
        "options": [
          "$0 - $100",
          "$100 - $150",
          "$150 - $200",
          "$200 - $300",
          "$300+"
        ],
        "example": "$150 - $200"
      },
      "email": {
        "type": "email",
        "required": true,
        "validation": "Must be valid email format",
        "format": "string",
        "example": "john.smith@example.com"
      },
      "firstName": {
        "type": "text",
        "required": true,
        "validation": "Must not be empty",
        "format": "string",
        "example": "John"
      },
      "lastName": {
        "type": "text",
        "required": true,
        "validation": "Must not be empty",
        "format": "string",
        "example": "Smith"
      },
      "phone": {
        "type": "tel",
        "required": true,
        "validation": "Must be at least 10 digits",
        "format": "string with +1 prefix (e.g., +13125551234)",
        "example": "+13125551234"
      }
    },
    "trackingFields": {
      "pageSlug": {
        "type": "auto-populated",
        "required": true,
        "options": [
          "1",
          "2",
          "3"
        ],
        "description": "Landing page number",
        "example": "1"
      },
      "offerName": {
        "type": "auto-populated",
        "required": true,
        "options": [
          "Powering What Matters Most",
          "Go Solar With $0 Down",
          "Your Solar Journey Starts Here"
        ],
        "description": "Offer headline based on landing page",
        "mapping": {
          "1": "Powering What Matters Most",
          "2": "Go Solar With $0 Down",
          "3": "Your Solar Journey Starts Here"
        },
        "example": "Powering What Matters Most"
      },
      "utmSource": {
        "type": "url-parameter",
        "required": false,
        "format": "string",
        "default": "",
        "description": "Traffic source (e.g., google, facebook, instagram)",
        "example": "google"
      },
      "utmCampaign": {
        "type": "url-parameter",
        "required": false,
        "format": "string",
        "default": "",
        "description": "Campaign identifier",
        "example": "solar-illinois-2026"
      },
      "utmAdset": {
        "type": "url-parameter",
        "required": false,
        "format": "string",
        "default": "",
        "description": "Ad set identifier",
        "example": "chicago-homeowners"
      },
      "utmAd": {
        "type": "url-parameter",
        "required": false,
        "format": "string",
        "default": "",
        "description": "Specific ad identifier",
        "example": "ad-123"
      },
      "fbclid": {
        "type": "url-parameter",
        "required": false,
        "format": "string",
        "default": "",
        "description": "Facebook Click ID",
        "example": "IwAR1234567890abcdefghijklmnop"
      },
      "submittedAt": {
        "type": "auto-generated",
        "required": true,
        "format": "ISO 8601 timestamp",
        "description": "Timestamp when form was submitted",
        "example": "2026-03-02T15:30:45.123Z"
      }
    }
  },
  "examplePayload": {
    "firstName": "John",
    "lastName": "Smith",
    "email": "john.smith@example.com",
    "phone": "+13125551234",
    "zipCode": "60601",
    "homeOwnership": "yes",
    "electricBill": "$150 - $200",
    "pageSlug": "1",
    "offerName": "Powering What Matters Most",
